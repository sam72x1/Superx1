# ── الماسح الشامل اللحظي — متغيّرات البيئة ──────────────────────
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية.

# الاعتماد (إلزامي) ─────────────────────────────────────────────
MASSIVE_API_KEY=ضع_مفتاح_Massive_هنا
TELEGRAM_BOT_TOKEN=ضع_توكن_بوت_تيليجرام
TELEGRAM_CHAT_ID=ضع_chat_id

# نقاط الوصول (افتراضي يشتغل؛ المفتاح نفسه يعمل على polygon.io أيضًا) ─
# MASSIVE_REST_BASE=https://api.massive.com
# MASSIVE_WS_URL=wss://socket.massive.com/stocks
HTTP_TIMEOUT=20             # مهلة كل نداء REST (ث)
HTTP_MAX_RETRIES=3          # إعادة المحاولة على الأعطال العابرة (مهلة/429/5xx)

# التخزين — لازم قرص دائم في Render (لمنع تكرار التنبيه) ─────────
DB_PATH=/var/data/runner_scanner.sqlite3

# حلقة المسح ────────────────────────────────────────────────────
POLL_INTERVAL_SEC=45
KEEPALIVE_PORT=10000
# أعلى N سهم صعودًا فقط نحلّلها كل دورة (قرار: 15)
TOP_N_RUNNERS=15

# تتبّع النتائج + تحديثات المتابعة + أداة التطوير ──────────────
OUTCOME_WINDOW_MIN=90      # نافذة متابعة السهم بعد التنبيه (دقائق)
MISSED_RISE_PCT=30         # مرفوض صعد ≥ هذا = فرصة فائتة
MISSED_ALERT_ENABLED=true  # تنبيه لحظي بالفرص الفائتة + سبب الرفض
SURGE_LEG_PCT=8            # قفزة جديدة ≥ هذا فوق آخر قمة = رسالة تحديث
DEV_MIN_SAMPLE=10          # أقل عدد نتائج محسومة قبل تقرير ذو معنى
DEV_REPORT_ON_CLOSE=true   # تفعيل تقرير التطوير المجدوَل + ملفات CSV
DEV_REPORT_WEEKDAYS=2,5    # أيام الإرسال (الرياض): الأربعاء=2 · السبت=5
DEV_REPORT_HOUR=5          # ساعة الإرسال فجرًا بالرياض (بعد الإغلاق)
DEV_COMPARE_WINDOW_DAYS=7  # نافذة «قبل/بعد»: آخر N يوم مقابل الـN السابقة (7=أسبوع)
DEV_TAIL_WARN_MULT=1.5     # صدق التوزيع: حذّر لو المتوسط ≥ الوسيط×هذا (المتوسط يخدع)

# العرض والبطاقة ────────────────────────────────────────────────
DISPLAY_TZ=Asia/Riyadh     # توقيت عرض وقت البطاقة
BUY_ZONE_PCT=1.3           # عرض منطقة الشراء فوق السعر%
SHORT_WARN_PCT=20          # شورت ≥ هذا = تحذير ضغط بيعي (يضرّ السهم)
# CODE_VERSION=            # يُملأ تلقائيًا من RENDER_GIT_COMMIT على Render

# الزناد والبوابات الصارمة (قابلة للمعايرة) ─────────────────────
TRIGGER_CHANGE_PCT=10      # حدّ أدنى للحركة؛ «أعلى 15» هو الفلتر الحقيقي
MAX_CHANGE_PCT=400         # سقف يسقط تشوّه الانقسام العكسي قبل قصّ الـ15
ENTRY_CHANGE_MAX_PCT=40    # لا تنبيه على سهم صعد ≥ هذا عن أمس (شريحة خاسرة −2%/صفقة؛ 0=تعطيل)
FILTER_DERIVATIVES=true    # استبعاد الوارنتات/اليونتات/الحقوق بالرمز
ALLOWED_TICKER_TYPES=CS,ADRC   # الأنواع المقبولة (سهم عادي/ADR)
EXCLUDE_OTC=true          # استبعاد OTC/pink (ناسداك/نيويورك فقط)
CHAMPIONS_ENABLED=true    # توريث أبطال الفترة السابقة (أولوية متابعة)
FLOAT_MAX=40000000
RVOL_MIN=5
VOLUME_MIN=300000
VOLUME_GATE_ENABLED=false  # ملغاة: RVol هو مقياس السيولة/النشاط الوحيد (الجلسات الثلاث)
PRICE_MIN=1
PRICE_MAX=30
PARABOLIC_VWAP_EXT_PCT=40
PARABOLIC_DAY_CHANGE_PCT=120
VWAP_GATE_ENABLED=true      # تنبيه فوق VWAP فقط (تحت VWAP 55% نجاح < تعادل)؛ false=إلغاء الفلتر

# الجاهزية الفنية (قرار المستخدم بالبيانات: ≥ 65/100) ───────────
TECH_READINESS_MIN=65      # 65 يحذف شريحة 60–65 الأضعف تاريخيًا (−0.56%/صفقة)
MOMENTUM_MIN_FLOOR=25
ALERT_SCORE_MIN=60
ADX_WEIGHT=7         # وزن ADX داخل الجاهزية (المؤشر الوحيد المتّسق؛ رُفع 5→7، عايره بالباكتيست)

# الخبر/المحفّز (إشارة تقوية لا بوّابة) ─────────────────────────
CATALYST_LOOKBACK_HOURS=48
CATALYST_SCORE_BONUS=8

# الوقف والأهداف ────────────────────────────────────────────────
STOP_FIXED_PCT=7           # الوقف = الدخول − 7% بالضبط (نسبة ثابتة، لا دعم)
STOP_MIN_PCT=4             # (غير مستخدَم للوقف الثابت؛ مُبقى للتوافق)
STOP_MAX_PCT=20            # (غير مستخدَم للوقف الثابت؛ مُبقى للتوافق)
TARGET_MAX_PCT=80          # سقف مسافة الهدف (يمنع أهدافًا بعيدة سخيفة)
TARGET_RECENT_HIGH_HOURS=4 # هدف = أعلى سعر في آخر N ساعة (نافذة متدحرجة داخل-اليوم؛ 0=تعطيل)
TARGET1_MIN_RR=0.5         # الهدف1 = أقرب مقاومة حقيقية بعائد/مخاطرة ≥ هذا (تخطّي الأقرب التافه؛ 0=تعطيل)
MIN_TARGET_PROFIT_PCT=10   # حد أدنى لسقف ربح الأهداف% (أبعد هدف)؛ تحت 10 = لا يستحق المخاطرة (0=معطّل)
PARTIAL_EXIT_FRACTION=0.5  # قياس الخروج الجزئي بالباكتيست: نسبة البيع عند الهدف1 (ظل، لا يغيّر الحيّ)

# المستشار الذكي (Claude) — «العين اللي ما تنام» (اختياري) ──────
# بدون المفتاح يشتغل البوت عادي، لكن بلا تحليل/بريفنغ/مساعد ذكي.
ANTHROPIC_API_KEY=          # مفتاح Anthropic لتفعيل الذكاء
ANTHROPIC_MODEL=claude-sonnet-4-6           # نموذج البريفنغ/المساعد
ANALYST_MODEL=claude-haiku-4-5-20251001     # تحليل كل تنبيه (أسرع/أرخص)
ANALYST_ENABLED=true        # محلّل ذكي لكل تنبيه (خبر/أطروحة/تحذير)
ADVISOR_ENABLED=true        # بريفنغ نهاية الجلسة على تيليجرام
ASSISTANT_ENABLED=true      # مساعد تيليجرام تفاعلي (/ask /status /top...)
ANALYST_BEARISH_PENALTY=12  # خصم درجة عند محفّز هبوطي (طرح/تخفيف)
POSTMORTEM_ENABLED=true     # تشريح سبب فشل/نجاح السهم (لماذا فشل؟)
POSTMORTEM_ON_STOP=true     # تشريح لحظي يصلك فور كسر الوقف

# الباكتيست التلقائي — يشتغل بنفسه أسبوعيًا ويرسل النتيجة (بلا تدخّل منك) ─
BACKTEST_ENABLED=true       # باكتيست أسبوعي تلقائي في الخلفية
BACKTEST_LOOKBACK_DAYS=45   # نافذة الاختبار (أيام تقويم ≈ 30 يوم تداول)
BACKTEST_WEEKDAY=5          # يوم التشغيل (الرياض): السبت=5
BACKTEST_HOUR=6            # ساعة التشغيل فجرًا (الرياض)
BACKTEST_SCAN_STEP_BARS=1   # محاكاة المسح المتكرّر: فحص كل N شمعة 5د (1=الأدقّ)
BACKTEST_TOP_N=45           # مرشّحون/يوم في الباكتيست (≈ اتحاد قادة 3 جلسات)
BACKTEST_HTTP_TIMEOUT=8     # مهلة نداءات الباكتيست (ث): فشل سريع بدل إعادات طويلة
BACKTEST_QUICK_DAYS=5       # /backtest اليدوي: نافذة المعاينة السريعة (أيام)
BACKTEST_QUICK_TOP_N=12     # /backtest اليدوي: مرشّحون/يوم في المعاينة
BACKTEST_QUICK_STEP=2       # /backtest اليدوي: فحص كل شمعتين 5د
BACKTEST_WORKERS=8          # جلب متوازٍ: أسهم تُعالَج معًا (يسرّع الشهر كثيرًا)
BACKTEST_SHADOW_RVOL=true   # قياس الظل: أداء افتراضي لمرفوضي RVol (قياس فقط)
BACKTEST_TRAIL_PCT=5        # ظلّ الوقف المتعقّب بعد هدف1 (%): قياس فجوة القمة (لا يُطبَّق)
BACKTEST_WIDE_T1_RR=0.5     # ظلّ توسيع الهدف1: عتبة عائد/مخاطرة لاختبار «دون 0.5» (قياس)
PREMARKET_CAUTION_ENABLED=true  # تحذير + أولوية أخفض لتنبيهات البريماركت (أضعف تاريخيًا)
AFTERHOURS_CAUTION_ENABLED=true  # تحذير الأفترهاوس (عيّنة 6 أشهر ضعيفة 33%؛ إعلام لا حذف)
PREMARKET_ALERTS_ENABLED=false  # تنبيهات البريماركت معطّلة (أولوية الدقّة: 59% مقابل 87%)؛ true=تغطية أوسع

# منهجية المستخدم: إعلام حسب الجلسة والموجة (دليل لا منفّذ) ─
OPENING_RANGE_MINUTES=30            # نافذة الافتتاح: أول N دقيقة رسمي (مُميِّز «سهم الماركت»)
SESSION_MOVE_HINT_ENABLED=true     # سطر «الحركة النموذجية لهذه الجلسة» (سياق تقريبي لا وعد)
SESSION_MOVE_PREMARKET_PCT=15      # بريماركت ~15%
SESSION_MOVE_OPEN_PCT=30           # أول نص ساعة رسمي (ضغط الافتتاح) ~30%
SESSION_MOVE_REGULAR_PCT=20        # بقية الرسمي ~20%
SESSION_MOVE_AFTERHOURS_PCT=25     # أفترهاوس ~20–30% (وسط)
LATE_WAVE_CAUTION_ENABLED=true     # تحذير «الموجة الأخيرة الأضعف» عند حركة متقدّمة
LATE_WAVE_RUN_PCT=40               # «حركة متقدّمة» — شبكة أمان لو عُطّلت ENTRY_CHANGE_MAX_PCT

# معايرة العتبات A/B — يقترح أفضل عتبات تاريخيًا (للمراجعة فقط، لا يطبّق) ─
BACKTEST_GRID_ENABLED=false             # شبكة المعايرة (ثقيلة ذاكرة؛ فعّلها على خادم أكبر)
BACKTEST_GRID_READINESS=55,60,65,70     # قيم تجربة TECH_READINESS_MIN
BACKTEST_GRID_FLOAT_MAX=40000000,60000000,75000000  # قيم تجربة FLOAT_MAX
BACKTEST_GRID_PARABOLIC=120,150         # قيم تجربة PARABOLIC_DAY_CHANGE_PCT
BACKTEST_GRID_MIN_DECISIVE=8            # أقل صفقات محسومة قبل الوثوق بتركيبة
BACKTEST_GRID_MIN_EDGE=3               # أقل تحسّن (نقاط %) كي نقترح التغيير
BACKTEST_NOTES_ENABLED=true            # ملاحظات تحليلية تُرسَل مع الباكتيست
BACKTEST_SAVE_DIR=                      # مجلد حفظ نتائج الباكتيست (فراغ=<مجلد القاعدة>/backtests)

# رادار التخفيف (SEC EDGAR) — يحذّر من الطرح القادم (مجاني، بلا مفتاح) ─
DILUTION_RADAR_ENABLED=true   # رصد ملفات SEC التخفيفية (S-1/424B/EFFECT)
DILUTION_ACTIVE_DAYS=45       # نافذة «طرح فعّال/وشيك» = خطر مرتفع
DILUTION_SHELF_DAYS=180       # نافذة «رفّ مُسجّل» = خطر متوسط
DILUTION_PENALTY=12           # خصم درجة عند طرح فعّال (يضرّ كالشورت)
# SEC تشترط ترويسة User-Agent تعريفية — ضع بريدك الحقيقي
SEC_USER_AGENT=RunnerScanner research your-email@example.com

# تكامل ريندر (اختياري — لحالة الخدمة وإعادة التشغيل من التيليجرام) ─
RENDER_API_KEY=             # من Render → Account Settings → API Keys
RENDER_SERVICE_ID=         # srv-xxxx (من رابط الخدمة)

# تشغيل ─────────────────────────────────────────────────────────
HALTS_ENABLED=true
DRY_RUN=false
LOG_LEVEL=INFO
